<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ACFAEF"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/bufferTextView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="----------------------------------"
        android:textSize="40sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/infoTextView"
        app:layout_constraintTop_toBottomOf="@+id/infoTextView" />

    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Level 3"
        android:textSize="45sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/bufferTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="40sp"
        android:text="----------------------------------"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/titleTextView" />

    <ImageView
        android:id="@+id/artImageView"
        android:layout_width="291dp"
        android:layout_height="212dp"
        app:layout_constraintEnd_toEndOf="@+id/bufferTextView"
        app:layout_constraintStart_toStartOf="@+id/bufferTextView"
        app:layout_constraintTop_toBottomOf="@+id/bufferTextView"
        app:srcCompat="@drawable/level_3" />

    <TextView
        android:id="@+id/infoTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Second password cracked, another obstacle passed. You make your way towards the exit.
It's nearly time. You hot wire a boat, ready to sail out into the ocean. But...the gate isn't opening.
SHOOT! You have to crack ONE more password, but it's the hardest one yet. And the guards are hot on
 your tail. The time you have here is the shortest. But you can do this. It's now
or never. Escape, or rot."
        android:textSize="22sp"
        app:layout_constraintBottom_toTopOf="@+id/bufferTextView2"
        app:layout_constraintEnd_toEndOf="@+id/artImageView"
        app:layout_constraintStart_toStartOf="@+id/artImageView"
        app:layout_constraintTop_toBottomOf="@+id/artImageView" />

    <Button
        android:id="@+id/startButton"
        android:layout_width="102dp"
        android:layout_height="61dp"
        android:text="Start"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bufferTextView2" />
</androidx.constraintlayout.widget.ConstraintLayout>